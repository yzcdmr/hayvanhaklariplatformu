---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Hayvan Hakları Platformu">

    <div class="flex min-h-screen bg-[#d9f1ff]">

        <!-- Sidebar -->
        <aside class="w-[320px] bg-[#bfe8ff] border-r border-blue-200 flex flex-col">

            <!-- Logo -->
            <div class="p-8 border-b border-blue-200">
                <h1 class="text-3xl font-black text-[#0f172a] leading-tight">
                    Hayvan Hakları
                    Platformu
                </h1>

                <p class="mt-3 text-sm text-slate-700">
                    Sessiz bırakılan canların sesi.
                </p>
            </div>

            <!-- Menu -->
            <nav class="flex flex-col gap-2 p-5">

                <!-- Active -->
                <a
                        href="/"
                        class="bg-[#0f172a] text-white px-5 py-4 rounded-2xl font-semibold"
                >
                    Ana Sayfa
                </a>

                <a
                        href="/manifesto"
                        class="text-slate-800 hover:bg-blue-100 px-5 py-4 rounded-2xl transition"
                >
                    Manifestomuz
                </a>

                <a
                        href="/haberler"
                        class="text-slate-800 hover:bg-blue-100 px-5 py-4 rounded-2xl transition"
                >
                    Haberler
                </a>

                <a
                        href="/hakkimizda"
                        class="text-slate-800 hover:bg-blue-100 px-5 py-4 rounded-2xl transition"
                >
                    Hakkımızda
                </a>

                <a
                        href="/information"
                        class="text-slate-800 hover:bg-blue-100 px-5 py-4 rounded-2xl transition"
                >
                    İletişim
                </a>

            </nav>

            <!-- Bottom -->
            <div class="mt-auto p-6 border-t border-blue-200">

                <div class="rounded-2xl bg-[#0f172a] p-5 text-white">
                    <p class="text-sm uppercase tracking-widest text-blue-200">
                        Manifesto
                    </p>

                    <p class="mt-3 text-lg font-semibold leading-7">
                        Yaşam hakkı pazarlık konusu değildir.
                    </p>
                </div>

            </div>

        </aside>

        <!-- Main -->
        <main class="flex-1">

            <!-- Hero -->
            <section class="relative h-screen overflow-hidden">

                <!-- Background -->
                <img
                        src="/images/hayvanhaklari1.png"
                        alt="Hayvan Hakları"
                        class="absolute inset-0 h-full w-full object-cover"
                />

                <!-- Overlay -->
                <div class="absolute inset-0 bg-black/45"></div>

                <!-- Content -->
                <div class="relative z-10 flex h-full items-center justify-between px-20">

                    <div class="max-w-4xl text-white">

                        <p class="mb-6 text-sm uppercase tracking-[0.35em] text-blue-200">
                            Hayvan Hakları Yayın Platformu
                        </p>

                        <h2 class="text-7xl font-black leading-tight">
                            Onların sesi yoksa,
                            bizim vicdanımız var.
                        </h2>

                        <p class="mt-8 max-w-2xl text-2xl leading-10 text-zinc-200">
                            Hayvan hakları ihlallerini görünür kılmak,
                            toplumsal farkındalık oluşturmak ve yaşam hakkını savunmak için buradayız.
                        </p>

                        <div class="mt-12 flex gap-5">

                            <!--<a
                                    href="/manifesto"
                                    class="rounded-2xl bg-[#0f172a] px-8 py-4 text-lg font-semibold hover:bg-slate-800"
                            >
                                Manifestoyu Oku
                            </a>-->

                            <a
                                    href="/haberler"
                                    class="rounded-2xl border border-white/50 bg-white/10 px-8 py-4 text-lg font-semibold backdrop-blur"
                            >
                                Haberleri Gör
                            </a>

                        </div>

                    </div>
                    <!-- Floating Video Card -->
                    <div class="absolute right-16 top-16 hidden xl:block z-20">

                        <div class="w-[360px] overflow-hidden rounded-[32px] border border-white/20 bg-white/10 backdrop-blur-xl shadow-2xl transition duration-500 hover:-translate-y-2 hover:bg-white/15">

                            <video
                                    autoplay
                                    muted
                                    loop
                                    playsinline
                                    class="h-[220px] w-full object-cover"
                            >
                                <source src="/videos/Manifesto.mp4" type="video/mp4" />
                            </video>

                        </div>

                    </div>
                </div>

            </section>

        </main>

    </div>

</BaseLayout>