---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
    Instagram,
    Twitter,
    Youtube
} from "lucide-astro";
---

<BaseLayout title="İletişim | Hayvan Hakları Platformu">
    <main class="min-h-screen bg-[#d9f1ff] px-8 py-12 text-slate-900">
        <section class="mx-auto max-w-5xl">
            <p class="text-sm font-bold uppercase tracking-[0.35em] text-[#0f172a]">
                İletişim
            </p>

            <h1 class="mt-5 max-w-3xl text-5xl font-black leading-tight">
                Bizimle iletişime geçin.
            </h1>

            <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-700">
                Haber, iş birliği, gönüllülük veya platformla ilgili görüşleriniz için
                bize ulaşabilirsiniz.
            </p>

            <div class="mt-12 grid gap-6 md:grid-cols-2">
                <div class="rounded-[28px] bg-white/70 p-8 shadow-xl">
                    <h2 class="text-2xl font-black">E-posta</h2>
                    <p class="mt-4 text-slate-700">Genel iletişim için:</p>
                    <a
                            href="mailto:hayvanhaklariplatformuturkiye@gmail.com"
                            class="mt-2 block break-all text-lg font-bold text-[#0f172a]"
                    >
                        hayvanhaklariplatformuturkiye@gmail.com
                    </a>
                </div>

                <div class="rounded-[28px] bg-[#0f172a] p-8 text-white shadow-xl">
                    <h2 class="text-2xl font-black">Sosyal Medya</h2>
                    <p class="mt-4 text-blue-100">
                        Güncel haberler ve duyurular için bizi takip edin.
                    </p>
                    <div class="mt-6 flex flex-col gap-4">
                        <a href="https://www.instagram.com/hayvanhaklariplatformuturkiye/"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="font-semibold hover:text-blue-200"><Instagram/>Instagram</a>
                        <a href="https://x.com/HayvanHTP"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="font-semibold hover:text-blue-200"><Twitter/>X / Twitter</a>
                        <a href="https://www.youtube.com/@HAYVANHAKLARIT%C3%9CRK%C4%B0YEPLATFORMU/featured"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="font-semibold hover:text-blue-200"><Youtube/>YouTube</a>
                    </div>
                </div>

                <div class="rounded-[28px] bg-white/70 p-8 shadow-xl md:col-span-2">
                    <h2 class="text-2xl font-black">Not</h2>
                    <p class="mt-4 max-w-3xl leading-8 text-slate-700">
                        Bu platform şimdilik haber ve farkındalık yayını yapmaktadır.
                        Acil kurtarma, veteriner müdahalesi veya resmi işlem merkezi
                        değildir. Acil durumlarda ilgili belediye, Tarım ve Orman İl/İlçe
                        Müdürlüğü veya kolluk birimleriyle iletişime geçilmelidir.
                    </p>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>