---
import BaseLayout from "../layouts/BaseLayout.astro";

const team = [
  { name: "Elif Kaya",    role: "Kurucu & Editör",          bio: "10 yıldır hayvan hakları aktivizmi yapan gazeteci. Çevre ve hayvan hakları alanında ödüllü yazılar kaleme aldı.", avatar: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&q=80" },
  { name: "Mert Demir",   role: "Deniz Hayatı Muhabiri",    bio: "Biyolog ve çevre gazetecisi. Akdeniz ve Karadeniz'deki deniz canlılarının korunması üzerine araştırmalar yürütüyor.", avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&q=80" },
  { name: "Selin Arslan", role: "Hukuk & Mevzuat",          bio: "Hayvan hakları alanında uzmanlaşmış avukat. Mevzuat takibi ve hukuki danışmanlık yapıyor.", avatar: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=200&q=80" },
  { name: "Ahmet Yılmaz", role: "Saha Muhabiri",            bio: "İstanbul ve çevresindeki kurtarma operasyonlarını takip eden bağımsız foto-muhabir.", avatar: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=200&q=80" },
];

const values = [
  { icon: "🔍", title: "Bağımsız Gazetecilik", desc: "Hiçbir siyasi ya da ticari çıkara bağlı değiliz. Haberlerimizi birincil kaynaklara ve saha verilerine dayandırıyoruz." },
  { icon: "⚖️", title: "Adalet Odaklı",        desc: "Hayvan hakları ihlallerini kayıt altına alarak faillerin hesap vermesini talep ediyoruz." },
  { icon: "🌍", title: "Sistematik Bakış",      desc: "Bireysel vakaların ötesinde yapısal sorunları görünür kılmaya çalışıyoruz." },
  { icon: "🤝", title: "Şeffaf Yapı",           desc: "Platformumuzun nasıl finanse edildiği ve nasıl çalıştığı konusunda tam şeffaflık ilkesine bağlıyız." },
];
---

<BaseLayout title="Hakkımızda | Hayvan Hakları Platformu">

  <!-- Hero -->
  <section class="bg-[#1C1814] text-white pt-16 pb-24 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -bottom-20 -left-20 w-96 h-96 bg-[#B5634B] rounded-full blur-3xl"></div>
      <div class="absolute top-0 right-0 w-72 h-72 bg-[#5C7A5E] rounded-full blur-3xl"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8">
      <span class="section-label text-[#D4856E]">Biz Kimiz</span>
      <h1 class="section-title text-white mt-3 max-w-3xl">
        <span class="text-white">Sessiz bırakılan canların</span> <span class="text-[#D4856E]">sesi</span>
          <span class="text-white">olmak için buradayız.</span>
      </h1>
      <p class="mt-6 text-[white/60] max-w-2xl text-lg leading-relaxed">
        2023'te kurulan Hayvan Hakları Türkiye Platformu, gönüllü gazeteciler,
        aktivistler ve akademisyenlerden oluşan bağımsız bir medya inisiyatifidir.
      </p>
    </div>
  </section>

  <!-- Mission / Vision -->
  <section class="mx-auto max-w-7xl px-5 sm:px-8 py-20">
    <div class="grid gap-8 lg:grid-cols-2">
      <div class="bg-white rounded-3xl border border-[#E8DDD2] p-8 sm:p-10">
        <div class="w-12 h-12 bg-[#F5EFE6] rounded-2xl flex items-center justify-center text-2xl mb-6">🎯</div>
        <h2 class="text-2xl font-black text-[#1C1814] mb-4">Misyonumuz</h2>
        <p class="text-[#6B5E55] leading-relaxed">
          Türkiye'de hayvan hakları ihlallerini belgelemek, kamuoyunu bilgilendirmek ve ilgili
          kurumları hesap vermeye davet etmek. Her haberde, her raporlamada bu misyonu merkeze alıyoruz.
        </p>
      </div>
      <div class="bg-[#1C1814] text-white rounded-3xl p-8 sm:p-10">
        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-2xl mb-6">🌿</div>
        <h2 class="text-2xl font-black mb-4">Vizyonumuz</h2>
        <p class="text-[white/60] leading-relaxed">
          Hayvan haklarının Türkiye'de etkili bir şekilde korunduğu, ihlallerin hesap vermeden
          geçmediği ve toplumun bu konuda bilinçlendiği bir geleceği inşa etmek.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-[#F5EFE6] py-20">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="text-center mb-12">
        <span class="section-label">İlkelerimiz</span>
        <h2 class="section-title">Neye İnanıyoruz?</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {values.map(v => (
          <div class="bg-white rounded-2xl border border-[#E8DDD2] p-6 text-center hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="text-4xl mb-4">{v.icon}</div>
            <h3 class="font-black text-[#1C1814] mb-2">{v.title}</h3>
            <p class="text-sm text-[#6B5E55] leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="mx-auto max-w-7xl px-5 sm:px-8 py-20">
    <div class="text-center mb-12">
      <span class="section-label">Ekibimiz</span>
      <h2 class="section-title">Bu Sesi Yükseltiyoruz</h2>
      <p class="mt-4 text-[#8A7B6F] max-w-xl mx-auto">
        Gönüllülük esasıyla çalışan, farklı uzmanlık alanlarından gelen bir ekibiz.
      </p>
    </div>
    <!--<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {team.map(member => (
        <div class="card text-center p-6 group">
          <div class="w-20 h-20 rounded-full overflow-hidden mx-auto mb-4 ring-4 ring-[#F5EFE6] group-hover:ring-[#B5634B] transition-all">
            <img src={member.avatar} alt={member.name} class="w-full h-full object-cover" />
          </div>
          <h3 class="font-black text-[#1C1814]">{member.name}</h3>
          <p class="text-xs font-semibold text-[#B5634B] mt-1 mb-3">{member.role}</p>
          <p class="text-sm text-[#6B5E55] leading-relaxed">{member.bio}</p>
        </div>
      ))}
    </div>-->
  </section>

  <!-- Timeline -->
  <section class="bg-[#1C1814] text-white py-20">
    <div class="mx-auto max-w-4xl px-5 sm:px-8">
      <div class="text-center mb-12">
        <span class="section-label text-[#D4856E]">Hikayemiz</span>
        <h2 class="section-title text-white">Nasıl Başladık?</h2>
      </div>
      <div class="space-y-8">
        <!--/*{[
          { year: "2023", title: "Kuruluş",        desc: "İstanbul'da bir grup gazeteci ve aktivist, hayvan hakları ihlallerini sistematik biçimde takip etmek için platformu kurdu." },
          { year: "2024", title: "Büyüme",          desc: "12.000'i aşkın takipçi, 50'den fazla destekçi kurum ve Türkiye'nin 4 büyük şehrinde saha muhabiri ağı oluşturuldu." },
          { year: "2025", title: "Meclis'e Taşıma", desc: "Raporlarımız ilk kez bir meclis soruşturmasına kaynak teşkil etti. Mevzuat haberlerimiz anaakım medyada da yer bulmaya başladı." },
          { year: "2026", title: "Bugün",           desc: "Genişleyen ekibimizle daha fazla haber, daha derin araştırmacı gazetecilik ve güçlü bir topluluk ile yolumuza devam ediyoruz." },
        ].map((item, i) => (
          <div class="flex gap-6 items-start">
            <div class="flex-shrink-0 w-16 text-center">
              <span class="text-[#B5634B] font-black text-lg">{item.year}</span>
            </div>
            <div class={`flex-1 pb-8 ${i < 3 ? 'border-b border-white/10' : ''}`}>
              <h3 class="font-black text-lg mb-2">{item.title}</h3>
              <p class="text-[white/60] leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}*/-->
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-7xl px-5 sm:px-8 py-20 text-center">
    <h2 class="section-title mb-4">Bu Davada Yer Almak İster Misiniz?</h2>
    <p class="text-[#8A7B6F] max-w-xl mx-auto mb-8">
      Gönüllü muhabir, fotoğrafçı, hukuk danışmanı veya sosyal medya katkıcısı olarak ekibimize katılabilirsiniz.
    </p>
    <a href="/iletisim" class="btn-accent text-lg px-8 py-4">Gönüllü Olmak İstiyorum</a>
  </section>

</BaseLayout>
